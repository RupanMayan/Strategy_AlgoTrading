//@version=6
strategy(
     title = "EMA 20 / EMA 50 LONG ONLY Strategy (3 Candle Delay)",
     overlay = true,
     initial_capital = 100000,
     default_qty_type = strategy.percent_of_equity,
     default_qty_value = 100,
     commission_type = strategy.commission.percent,
     commission_value = 0.1
)

// === INPUTS ===
shortLen = input.int(20, title="Short EMA Length")
longLen  = input.int(50, title="Long EMA Length")
delayBars = input.int(3, title="Entry Delay (Candles)")

// === EMA CALCULATION ===
emaShort = ta.ema(close, shortLen)
emaLong  = ta.ema(close, longLen)

// === PLOTS ===
plot(emaShort, title="EMA 20", color=color.green, linewidth=2)
plot(emaLong, title="EMA 50", color=color.red, linewidth=2)

// === ORIGINAL CROSS SIGNAL ===
bullCross = ta.crossover(emaShort, emaLong)
bearCross = ta.crossunder(emaShort, emaLong)

// === DELAYED ENTRY CONDITION ===
// Bullish cross occurred `delayBars` ago
delayedLongSignal =
     bullCross[delayBars] and
     emaShort > emaLong

exitSignal =
     bearCross

// === EXECUTION LOGIC ===
if delayedLongSignal
    strategy.entry("BUY", strategy.long)

if exitSignal
    strategy.close("BUY")
