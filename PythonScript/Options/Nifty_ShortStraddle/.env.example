# ── Nifty Short Straddle — Environment Variables ────────────────────────────
# Copy this file to .env and fill in your real credentials.
# .env is gitignored — never commit real secrets.
#
# These override the corresponding config.toml values:
#   OPENALGO_APIKEY      → [connection] api_key
#   OPENALGO_USERNAME    → [telegram]   username  (OpenAlgo login — primary notification channel)
#   TELEGRAM_BOT_TOKEN   → [telegram]   bot_token (fallback only — when OpenAlgo is down)
#   TELEGRAM_CHAT_ID     → [telegram]   chat_id   (fallback only — when OpenAlgo is down)

OPENALGO_APIKEY=your_openalgo_api_key_here
OPENALGO_USERNAME=your_openalgo_login_username_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
